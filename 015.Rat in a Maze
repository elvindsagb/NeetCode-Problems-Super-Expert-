Backtracking + Path Generation.

--------------------------------------------------------------------------

maze = [
    [1,0,0,0],
    [1,1,0,1],
    [0,1,0,0],
    [1,1,1,1]
]

n = len(maze)

solution = []

for _ in range(n):
    solution.append([0]*n)

def solve(x, y):

    if x == n-1 and y == n-1:

        solution[x][y] = 1

        return True

    if (
        x >= 0 and
        y >= 0 and
        x < n and
        y < n and
        maze[x][y] == 1
    ):

        solution[x][y] = 1

        if solve(x+1, y):
            return True

        if solve(x, y+1):
            return True

        solution[x][y] = 0

    return False


if solve(0,0):

    for row in solution:
        print(row)

else:
    print("No Path")
