import heapq

def skyline(buildings):

    events = []

    for l, r, h in buildings:

        events.append((l, -h, r))
        events.append((r, 0, 0))

    events.sort()

    result = []

    heap = [(0, float('inf'))]

    prev_height = 0

    for x, neg_h, r in events:

        while heap and heap[0][1] <= x:
            heapq.heappop(heap)

        if neg_h:
            heapq.heappush(
                heap,
                (neg_h, r)
            )

        curr_height = -heap[0][0]

        if curr_height != prev_height:

            result.append([x, curr_height])

            prev_height = curr_height

    return result


buildings = [
    [2,9,10],
    [3,7,15],
    [5,12,12],
    [15,20,10],
    [19,24,8]
]

print(skyline(buildings))
