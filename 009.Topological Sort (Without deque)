class Graph:

    def __init__(self, n):

        self.n = n

        self.graph = [[] for _ in range(n)]

    def add_edge(self, u, v):
        self.graph[u].append(v)

    def topo(self):

        indegree = [0] * self.n

        for u in range(self.n):

            for v in self.graph[u]:
                indegree[v] += 1

        queue = []

        for i in range(self.n):
            if indegree[i] == 0:
                queue.append(i)

        result = []

        front = 0

        while front < len(queue):

            node = queue[front]
            front += 1

            result.append(node)

            for nei in self.graph[node]:

                indegree[nei] -= 1

                if indegree[nei] == 0:
                    queue.append(nei)

        return result


g = Graph(6)

g.add_edge(5,2)
g.add_edge(5,0)
g.add_edge(4,0)
g.add_edge(4,1)
g.add_edge(2,3)
g.add_edge(3,1)

print(g.topo())
