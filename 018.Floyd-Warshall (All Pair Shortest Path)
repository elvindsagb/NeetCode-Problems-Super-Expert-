INF = 10**9

graph = [
    [0, 3, INF, 5],
    [2, 0, INF, 4],
    [INF, 1, 0, INF],
    [INF, INF, 2, 0]
]

n = len(graph)

for k in range(n):

    for i in range(n):

        for j in range(n):

            if (
                graph[i][k]
                +
                graph[k][j]
                <
                graph[i][j]
            ):

                graph[i][j] = (
                    graph[i][k]
                    +
                    graph[k][j]
                )

for row in graph:
    print(row)
